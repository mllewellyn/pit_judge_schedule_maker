# ── FRC Pit Judge Scheduler — environment variables ──────────────────────────
#
# Only needed for local development with mock data.
# The TBA API key is hardcoded in src/config.js.
#
# ─────────────────────────────────────────────────────────────────────────────

# Set to "true" to run with mock data instead of the real TBA API.
# Use "npm run dev:mock" instead of setting this manually.
VITE_MOCK_MODE=false
