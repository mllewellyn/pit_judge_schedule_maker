# ── FRC Pit Judge Scheduler — environment variables ──────────────────────────
#
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — your key stays off GitHub.
#
# ─────────────────────────────────────────────────────────────────────────────

# Your read-only TBA API key.
# Register at https://www.thebluealliance.com/account
# Leave blank when running in mock mode.
VITE_TBA_KEY=your_key_here

# Set to "true" to run with mock data instead of the real TBA API.
# Use "npm run dev:mock" instead of setting this manually.
VITE_MOCK_MODE=false
